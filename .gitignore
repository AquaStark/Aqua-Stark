dist/
build/
.cache/
.next/
out/

# 📂 Environment configuration and secrets
.env
.env.local
.env.development
.env.production

# 📂 Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# 📂 Editor configuration files
.vscode/
.idea/
.DS_Store

